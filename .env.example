# ─────────────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in real values. The compose file
# refuses to start when any required variable is missing or empty.
# `.env` is gitignored — never commit your filled-in copy.
# ─────────────────────────────────────────────────────────────────────

# Postgres password. Used by both the postgres container and the
# backend's DATABASE_URL. Pick anything strong; the DB is only exposed
# to the docker network in production, but the same value seeds both
# sides so don't ship the demo value.
POSTGRES_PASSWORD=replace-me-with-something-random

# Fernet key used to encrypt every *_enc column in the `settings` row
# (LLM API keys, search keys, GitHub PAT, Apify token, LinkedIn cookie,
# LinkedIn password if "Remember" was checked, SMTP password, etc.).
#
# Generate a fresh one with:
#   python -c "import secrets,base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
#
# Losing this key makes all stored secrets unrecoverable — back it up.
RECRUITER_SETTINGS_KEY=

# Bootstrap admin login — created on the first start of an empty DB.
# After first start, change the password from Settings → Profile.
RECRUITER_DEFAULT_ACCOUNT_EMAIL=you@example.com
RECRUITER_DEFAULT_ACCOUNT_PASSWORD=

# Optional: extend the CSRF Origin allowlist beyond the default
# http://localhost:8088. Comma-separated list, no trailing slash.
# Needed when you reach the stack via a different hostname (e.g.
# LAN IP, mDNS .local, reverse-proxied domain).
#   RECRUITER_ALLOWED_ORIGINS=http://localhost:8088,http://192.168.1.42:8088
RECRUITER_ALLOWED_ORIGINS=

# Optional: LinkedIn `li_at` session cookie. When set, LinkedIn URL
# adds are scraped via headless Chromium with this cookie. Most users
# set this via Settings → Sourcing → Connect LinkedIn instead.
RECRUITER_LINKEDIN_LI_AT=

# Optional: local OpenAI-compat LLM API key, when using a local
# inference server instead of Anthropic.
RECRUITER_LOCAL_LLM_API_KEY=

# Secret key for the bundled SearXNG search container. SearXNG ships with
# the search provider option `searxng` — set this and pick `searxng` in
# Settings → Sourcing to use the self-hosted, no-third-party-key search.
# Generate via: openssl rand -hex 32
# If unset, the compose container will start with the YAML placeholder
# "change-me" — fine for local dev, do not ship that to production.
SEARXNG_SECRET=
